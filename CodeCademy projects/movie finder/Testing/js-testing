// Filter books based on search input and render filtered books to the DOM
const filterBooks = (search) => {
  const extract = flattenObjectValuesIntoArray(books)
  const result = extract.filter((item) => item.includes(search)) 
  const searchResult = result.map((arg) => arg[0])
  let newBooks = books.slice()
  let book = []
  for(let i = 0; i < newBooks.length;i++){    
    for(let j = 0; j < searchResult.length; j++){
      if(books[i].title === searchResult[j]){
        book.push(newBooks[i])
      }
    }
  }
    return book
};

